{
  "name": "project-alpha-nest-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype NestJS backend for Project Alpha schema generation.",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "node node_modules/ts-node/dist/bin.js src/main.ts",
    "test": "npm run build && node --test test/smoke.test.js",
    "test:e2e": "npm run test"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sql.js": "^1.13.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.22"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
